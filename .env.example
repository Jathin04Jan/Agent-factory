# ── Trigger source ──────────────────────────────────────────────────
# "slack" = prompt-driven (post "build: ..." in the channel, no Jira needed)
# "jira"  = ticket-driven (the full pipeline)
TRIGGER=slack

# ── Jira (only needed when TRIGGER=jira) ────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your-atlassian-api-token
# Only tickets matching this JQL get picked up — the "ai-agent" label is your on/off switch
JIRA_JQL=labels = "ai-agent" AND status = "To Do" ORDER BY created ASC
JIRA_POLL_SECONDS=45
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_DONE=Done

# ── GitHub (gh CLI must already be authenticated on the VM) ─────────
GITHUB_REPO=yourorg/yourrepo
DEFAULT_BRANCH=develop
AUTO_MERGE=true
MERGE_METHOD=squash

# ── Slack ───────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123456789
APPROVAL_TIMEOUT_HOURS=24

# ── Workspace / sandbox ─────────────────────────────────────────────
WORK_DIR=/opt/agent-factory/workspaces
SANDBOX_UP_CMD=docker compose up -d --build
SANDBOX_DOWN_CMD=docker compose down -v
# The URL your team opens to test (VM IP + the port your compose file exposes)
SANDBOX_URL=http://YOUR_VM_IP:3000
# Optional command the orchestrator runs to verify before preview (leave empty to skip)
VERIFY_CMD=

# ── Claude Code ─────────────────────────────────────────────────────
CLAUDE_BIN=claude
CLAUDE_MAX_TURNS=80
CLAUDE_TIMEOUT_SECONDS=3600

# ── Phased pipeline (plan → implement → review) ─────────────────────
# Ticket types that get architect + reviewer phases. In Slack mode,
# "build:" = Feature (phased), "fix:" = Bug (single-phase, faster/cheaper).
PHASED_TYPES=feature,story,new feature
MAX_REVIEW_CYCLES=2

# ── Guardrails ──────────────────────────────────────────────────────
MAX_FIX_ATTEMPTS=3
PROTECTED_PATHS=.github/,.githooks/,infra/,Dockerfile,docker-compose
